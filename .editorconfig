root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yaml,yml,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[justfile]
indent_style = space
indent_size = 4

[*.odin]
indent_style = tab
indent_size = 4

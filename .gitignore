# Search index — rebuilt locally per machine
content/index/

# Profiling captures — large binary traces
playground/profiles/
*.spall
*.pdb
*.ctf

# Build artifacts
build/
target/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Node (tree-sitter, etc.)
node_modules/

# Local user overrides
local.toml

# Per-machine agent settings
.claude/

# Locally-published digests
content/outputs/

# Cloned third-party repos (have their own .git)
content/sources/tier3-community/odin-examples/

# Playground scratch files — only scratch.odin and README.md are tracked
playground/*.odin
!playground/scratch.odin

# Bootstrap log artifacts
bootstrap-out.log

# Built Odin binaries
tools/lessons-check/lessons-check.exe
tools/lessons-check/lessons-check
lessons/**/.lessons-check.odin

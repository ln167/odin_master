# Profiling captures — large binary traces
profiles/
*.spall
*.pdb
*.ctf

# Build artifacts
build/
target/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Node (tree-sitter, qmd cache, etc.)
node_modules/

# Local user overrides
local.toml

# Per-machine agent settings
.claude/settings.local.json

# Cloned third-party repos (have their own .git)
content/domains/odin/source/raw/tier3-community/odin-examples/

# Scratch files — only scratch.odin and README.md are tracked
scratch/*.odin
!scratch/scratch.odin

# Built Odin binaries (lessons-check)
tools/domains/odin/lessons-check/lessons-check.exe
tools/domains/odin/lessons-check/lessons-check
content/domains/odin/vault/lessons/**/.lessons-check.odin

# qmd local cache (per-machine; index lives elsewhere)
.qmd/
